# Plex server connection
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here

# Database paths (defaults to ~/.plexmix/ or PLEXMIX_DATA_DIR)
DATABASE_PATH=~/.plexmix/plexmix.db
DATABASE_FAISS_INDEX_PATH=~/.plexmix/embeddings.index

# Logging
LOG_LEVEL=INFO

# AI provider API keys
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# Docker / container settings
# PLEXMIX_DATA_DIR=/data          # Override default data directory (~/.plexmix)
# PLEXMIX_UI_HOST=0.0.0.0         # Bind UI to all interfaces (needed in Docker)

# UI settings
# PLEXMIX_UI_PASSWORD=             # Optional password to protect the web UI

# Audio analysis settings
# AUDIO_ENABLED=false              # Enable audio feature analysis
# AUDIO_ANALYZE_ON_SYNC=false      # Run analysis during sync
